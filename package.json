{
  "name": "h-player",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "expo:start": "expo start --dev-client",
    "expo:android": "expo run:android",
    "eas:build:dev": "eas build -p android --profile development",
    "eas:build:preview": "eas build -p android --profile preview",
    "eas:build:production": "eas build -p android --profile production",
    "android:lock": "cd android && gradlew.bat dependencies --write-locks",
    "android:test:unit": "cd android && gradlew.bat testDebugUnitTest",
    "android:test:instrumented": "cd android && gradlew.bat connectedDebugAndroidTest",
    "start": "react-native start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.1.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "^55.0.4",
    "expo-dev-client": "~55.0.10",
    "react": "19.0.0",
    "react-native": "0.78.0",
    "react-native-gesture-handler": "^2.21.0",
    "react-native-reanimated": "^3.17.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native-community/cli": "^18.0.0",
    "@react-native-community/cli-platform-android": "^18.0.0",
    "@react-native/babel-preset": "0.78.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "typescript": "^5.7.2"
  }
}
